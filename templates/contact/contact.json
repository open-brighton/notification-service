{
  "Template": {
    "TemplateName": "contact",
    "SubjectPart": "New Contact Form Submission — OpenBrighton",
    "TextPart": "OpenBrighton — New Contact Form Submission\n==========================================\n\nName:    {{name}}\nEmail:   {{email}}\n\nMessage:\n{{message}}\n\n--\nOpenBrighton | Brighton, MA\nhttps://openbrighton.org",
    "HtmlPart": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Contact Form Submission</title>\n</head>\n<body style=\"margin:0;padding:0;background-color:#000721;font-family:Arial,Helvetica,sans-serif;\">\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#000721;\">\n    <tr>\n      <td align=\"center\" style=\"padding:40px 20px;\">\n        <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px;\">\n\n          <!-- Header -->\n          <tr>\n            <td align=\"center\" style=\"padding:40px 0 32px 0;\">\n              <img src=\"https://openbrighton.org/logo.svg\" alt=\"OpenBrighton\" width=\"72\" height=\"72\" style=\"display:block;margin:0 auto;\">\n              <p style=\"color:#F1DFB5;font-size:20px;font-weight:bold;letter-spacing:3px;margin:14px 0 0 0;text-transform:uppercase;\">OpenBrighton</p>\n            </td>\n          </tr>\n\n          <!-- Card -->\n          <tr>\n            <td style=\"background-color:#0C2259;border-radius:10px;padding:36px 40px;\">\n              <h2 style=\"color:#F1DFB5;font-size:18px;margin:0 0 28px 0;font-weight:600;letter-spacing:0.5px;\">New Contact Form Submission</h2>\n\n              <!-- Name -->\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:22px;\">\n                <tr>\n                  <td style=\"padding-bottom:5px;\">\n                    <p style=\"color:#F1DFB5;opacity:0.55;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;margin:0;\">Name</p>\n                  </td>\n                </tr>\n                <tr>\n                  <td style=\"border-left:3px solid #F1DFB5;padding-left:12px;\">\n                    <p style=\"color:#F1DFB5;font-size:16px;margin:0;line-height:1.5;\">{{name}}</p>\n                  </td>\n                </tr>\n              </table>\n\n              <!-- Email -->\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:22px;\">\n                <tr>\n                  <td style=\"padding-bottom:5px;\">\n                    <p style=\"color:#F1DFB5;opacity:0.55;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;margin:0;\">Email</p>\n                  </td>\n                </tr>\n                <tr>\n                  <td style=\"border-left:3px solid #F1DFB5;padding-left:12px;\">\n                    <p style=\"color:#F1DFB5;font-size:16px;margin:0;line-height:1.5;\">\n                      <a href=\"mailto:{{email}}\" style=\"color:#F1DFB5;text-decoration:underline;\">{{email}}</a>\n                    </p>\n                  </td>\n                </tr>\n              </table>\n\n              <!-- Message -->\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n                <tr>\n                  <td style=\"padding-bottom:5px;\">\n                    <p style=\"color:#F1DFB5;opacity:0.55;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;margin:0;\">Message</p>\n                  </td>\n                </tr>\n                <tr>\n                  <td style=\"border-left:3px solid #F1DFB5;padding-left:12px;\">\n                    <p style=\"color:#F1DFB5;font-size:16px;margin:0;line-height:1.7;\">{{message}}</p>\n                  </td>\n                </tr>\n              </table>\n\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td align=\"center\" style=\"padding:28px 0 0 0;\">\n              <p style=\"color:#F1DFB5;opacity:0.4;font-size:12px;margin:0;line-height:1.8;\">\n                OpenBrighton &bull; Brighton, MA<br>\n                <a href=\"https://openbrighton.org\" style=\"color:#F1DFB5;text-decoration:none;\">openbrighton.org</a>\n              </p>\n            </td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>"
  }
}