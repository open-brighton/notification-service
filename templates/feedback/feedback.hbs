<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feedback Submission</title>
</head>
<body style="margin:0;padding:0;background-color:#000721;font-family:Arial,Helvetica,sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#000721;">
    <tr>
      <td align="center" style="padding:40px 20px;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;">

          <!-- Header -->
          <tr>
            <td align="center" style="padding:40px 0 32px 0;">
              <img src="https://openbrighton.org/logo.png" alt="OpenBrighton" width="72" height="72" style="display:block;margin:0 auto;">
              <p style="color:#F1DFB5;font-size:20px;font-weight:bold;letter-spacing:3px;margin:14px 0 0 0;text-transform:uppercase;">OpenBrighton</p>
            </td>
          </tr>

          <!-- Card -->
          <tr>
            <td style="background-color:#0C2259;border-radius:10px;padding:36px 40px;">
              <h2 style="color:#F1DFB5;font-size:18px;margin:0 0 28px 0;font-weight:600;letter-spacing:0.5px;">New Feedback Submission</h2>

              <!-- Email -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:22px;">
                <tr>
                  <td style="padding-bottom:5px;">
                    <p style="color:#F1DFB5;opacity:0.55;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;margin:0;">Email</p>
                  </td>
                </tr>
                <tr>
                  <td style="border-left:3px solid #F1DFB5;padding-left:12px;">
                    <p style="color:#F1DFB5;font-size:16px;margin:0;line-height:1.5;">
                      <a href="mailto:{{email}}" style="color:#F1DFB5;text-decoration:underline;">{{email}}</a>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Category -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:22px;">
                <tr>
                  <td style="padding-bottom:5px;">
                    <p style="color:#F1DFB5;opacity:0.55;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;margin:0;">Category</p>
                  </td>
                </tr>
                <tr>
                  <td style="border-left:3px solid #F1DFB5;padding-left:12px;">
                    <p style="color:#F1DFB5;font-size:16px;margin:0;line-height:1.5;">{{category}}</p>
                  </td>
                </tr>
              </table>

              <!-- Message -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="padding-bottom:5px;">
                    <p style="color:#F1DFB5;opacity:0.55;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;margin:0;">Message</p>
                  </td>
                </tr>
                <tr>
                  <td style="border-left:3px solid #F1DFB5;padding-left:12px;">
                    <p style="color:#F1DFB5;font-size:16px;margin:0;line-height:1.7;">{{message}}</p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding:28px 0 0 0;">
              <p style="color:#F1DFB5;opacity:0.4;font-size:12px;margin:0;line-height:1.8;">
                OpenBrighton &bull; Brighton, MA<br>
                <a href="https://openbrighton.org" style="color:#F1DFB5;text-decoration:none;">openbrighton.org</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>